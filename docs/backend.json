
{
  "entities": {
    "Driver": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Driver",
      "type": "object",
      "description": "Representa a un conductor del sistema de rutas escolares.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "routeNumber": {
          "type": "string"
        },
        "licensePlate": {
          "type": "string"
        },
        "contactNumber": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "routeNumber",
        "licensePlate",
        "isActive",
        "createdAt"
      ]
    },
    "RouteLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RouteLog",
      "type": "object",
      "description": "Registro diario de check-in y check-out de rutas.",
      "properties": {
        "id": {
          "type": "string"
        },
        "driverId": {
          "type": "string"
        },
        "routeNumber": {
          "type": "string"
        },
        "licensePlate": {
          "type": "string"
        },
        "logDate": {
          "type": "string",
          "format": "date"
        },
        "sede": {
          "type": "string",
          "enum": [
            "Preescolar",
            "Bachillerato"
          ]
        },
        "morningCheckIn": {
          "type": "number"
        },
        "morningCheckOut": {
          "type": "number"
        },
        "morningObservations": {
          "type": "string"
        },
        "morningSignature": {
          "type": "string"
        },
        "afternoonCheckIn": {
          "type": "number"
        },
        "afternoonCheckOut": {
          "type": "number"
        },
        "afternoonObservations": {
          "type": "string"
        },
        "afternoonSignature": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "driverId",
        "routeNumber",
        "licensePlate",
        "logDate",
        "createdAt",
        "sede"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/roles_admin/{adminId}": {
      "schema": "adminRole",
      "description": "Colección de roles de administrador."
    },
    "/drivers/{driverId}": {
      "schema": "Driver",
      "description": "Colección de conductores."
    },
    "/routeLogs/{routeLogId}": {
      "schema": "RouteLog",
      "description": "Colección de registros de ruta."
    }
  }
}
