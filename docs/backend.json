{
  "entities": {
    "Driver": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Driver",
      "type": "object",
      "description": "Represents a driver who performs routes, managed through an administrator panel.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Driver entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the driver."
        },
        "routeNumber": {
          "type": "string",
          "description": "The specific route number assigned to this driver."
        },
        "licensePlate": {
          "type": "string",
          "description": "The license plate of the vehicle assigned to this driver."
        },
        "contactNumber": {
          "type": "string",
          "description": "The primary contact phone number for the driver."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the driver is currently active."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "routeNumber",
        "licensePlate",
        "isActive",
        "createdAt"
      ]
    },
    "RouteLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RouteLog",
      "type": "object",
      "description": "Records the daily check-in and check-out times.",
      "properties": {
        "id": {
          "type": "string"
        },
        "driverId": {
          "type": "string"
        },
        "routeNumber": {
          "type": "string"
        },
        "licensePlate": {
          "type": "string"
        },
        "logDate": {
          "type": "string",
          "format": "date"
        },
        "sede": {
          "type": "string",
          "enum": [
            "Preescolar",
            "Bachillerato"
          ]
        },
        "morningCheckIn": {
          "type": "number"
        },
        "morningCheckOut": {
          "type": "number"
        },
        "morningObservations": {
          "type": "string"
        },
        "morningSignature": {
          "type": "string"
        },
        "afternoonCheckIn": {
          "type": "number"
        },
        "afternoonCheckOut": {
          "type": "number"
        },
        "afternoonObservations": {
          "type": "string"
        },
        "afternoonSignature": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "driverId",
        "routeNumber",
        "licensePlate",
        "logDate",
        "createdAt",
        "sede"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/roles_admin/{adminId}": {
      "schema": "adminRole",
      "description": "Admin roles collection."
    },
    "/drivers/{driverId}": {
      "schema": "Driver",
      "description": "Drivers collection."
    },
    "/routeLogs/{routeLogId}": {
      "schema": "RouteLog",
      "description": "Route logs collection."
    }
  }
}
